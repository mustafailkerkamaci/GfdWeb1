<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <meta name="description" content="@(ViewData["Description"] ?? "Genç Finansçılar Derneği (GFD), iş dünyası ile gençler arasında köprü kurarak geleceğin finans liderlerini yetiştirmeyi hedefleyen vizyoner bir sivil toplum kuruluşudur.")">
    <meta name="keywords" content="Genç Finansçılar Derneği, GFD, genç finansçılar, Atatürk Üniversitesi Oltu MYO, finans kulübü, ekonomi derneği, erzurum etkinlik, oltu finans, yatırım, borsa, hisse senedi, kariyer planlama, gençlik, sivil toplum kuruluşu, STK, liderlik, iş dünyası öğrenci buluşmaları, öğrenci topluluğu, ulusal genç zirveler, finans zirvesi, ekonomi seminerleri, girişimcilik, finansal okuryazarlık, cv hazırlama, network, Erzurum STK, üniversite öğrenci kulüpleri, Oltu sivil toplum, finans eğitimi">
    <meta name="author" content="Genç Finansçılar Derneği">
    <title>@(ViewData["Title"] ?? "Ana Sayfa") | Genç Finansçılar Derneği (GFD)</title>

    <style>
        /* Variables & Reset */
        :root {
            --turk-mavisi: #3b82f6;
            --mor-vurgu: #8b5cf6;
            --beyaz: #ffffff;
            --koyu-yazi: #111827;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: #130a1f !important;
            background-image: radial-gradient(circle at 10% 20%, rgba(59, 130, 246, 0.25) 0%, transparent 45%), radial-gradient(circle at 90% 80%, rgba(10, 17, 40, 0.9) 0%, transparent 55%), radial-gradient(circle at 50% 50%, rgba(139, 92, 246, 0.15) 0%, transparent 60%) !important;
            background-attachment: fixed !important;
            color: #f8f9fa !important;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        main, section, .pb-3 {
            background-color: transparent !important;
        }

        .main-content,
        .main-content h1, .main-content h2, .main-content h3, .main-content h4, .main-content h5, .main-content h6,
        .main-content p, .main-content span, .main-content li, .main-content b, .main-content strong, .main-content div, .main-content td, .main-content th {
            color: #d1d5db !important;
        }

        /* NAVBAR (BEYAZ TEMA VE SİYAH YAZILAR) */
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 5%;
            height: 90px;
            background-color: rgba(255, 255, 255, 0.95) !important; /* BEYAZ ARKA PLAN */
            backdrop-filter: blur(15px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            display: flex;
            align-items: center;
            height: 100%;
            text-decoration: none;
            z-index: 1002;
            max-width: 75%;
        }

            .logo img {
                height: 60px !important;
                width: auto;
                object-fit: contain;
            }

        .logo-text {
            font-size: 18px;
            font-weight: 800;
            margin-left: 12px;
            background: linear-gradient(to right, #8b5cf6, #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            line-height: 1.2;
            white-space: nowrap;
        }

        .menu {
            display: flex;
            gap: 25px;
            align-items: center;
        }

            /* Navbar Yazıları Siyah Yapıldı */
            .menu a {
                text-decoration: none;
                color: var(--koyu-yazi) !important;
                font-weight: 700;
                font-size: 15px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                transition: 0.3s;
            }

                .menu a:hover {
                    color: var(--turk-mavisi) !important;
                }

        /* DROPDOWN (BEYAZ TEMA UYUMU) */
        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            background-color: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            min-width: 220px;
            box-shadow: 0px 8px 20px rgba(0,0,0,0.15);
            border-radius: 8px;
            overflow: hidden;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .dropdown-content a {
                color: var(--koyu-yazi) !important;
                padding: 12px 16px;
                display: block;
                font-size: 14px;
                text-transform: none;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

                .dropdown-content a:hover {
                    background-color: rgba(59, 130, 246, 0.1);
                    color: var(--turk-mavisi) !important;
                    padding-left: 20px;
                }

        .dropdown:hover .dropdown-content {
            display: block;
        }

        /* HAMBURGER (SİYAH YAPILDI) */
        .hamburger {
            display: none;
            flex-direction: column;
            justify-content: space-between;
            width: 30px;
            height: 20px;
            cursor: pointer;
            z-index: 1003;
        }

            .hamburger span {
                width: 100%;
                height: 3px;
                background-color: var(--koyu-yazi);
                border-radius: 3px;
                transition: all 0.3s ease;
            }

        /* YÖNETİM KURULU VE EKRANA SIĞMAYAN KARTLAR İÇİN MOBİL DÜZELTME */
        @@media (max-width: 768px) {
            .main-content

        {
            overflow-x: hidden !important;
        }
        /* Flex yapılarını zorla alt alta dizer, yan yana sıkışıp bozulmasını engeller */
        .main-content [style*="display: flex"], .main-content [class*="row"] {
            flex-wrap: wrap !important;
            justify-content: center !important;
        }
        /* Kartların ekrandan taşmasını engeller */
        .main-content > div, .main-content section > div, .main-content .container > div {
            max-width: 100vw !important;
            box-sizing: border-box;
        }

        }

        /* RESPONSIVE (MÜKEMMEL MOBİL UYUM) */
        @@media (max-width: 1100px) {
            .logo-text

        {
            font-size: 15px;
        }

        .menu {
            gap: 15px;
        }

            .menu a {
                font-size: 13px;
            }

        }

        @@media (max-width: 992px) {
            nav

        {
            height: 80px;
            padding: 0 20px;
            justify-content: space-between;
        }

        .hamburger {
            display: flex;
        }

        /* Mobil Menü Arka Planı Beyaz Yapıldı */
        .menu {
            position: fixed;
            top: 0;
            right: -100%;
            width: 280px;
            height: 100vh;
            background-color: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            flex-direction: column;
            justify-content: flex-start;
            padding-top: 100px;
            align-items: center;
            gap: 25px;
            transition: right 0.4s ease-in-out;
            box-shadow: -5px 0 20px rgba(0,0,0,0.15);
            border-left: 1px solid rgba(0,0,0,0.05);
            z-index: 1001;
            overflow-y: auto;
        }

            .menu.active {
                right: 0;
            }

        /* Animasyonlu X İkonu */
        .hamburger.active span:nth-child(1) {
            transform: translateY(8.5px) rotate(45deg);
            background-color: var(--turk-mavisi);
        }

        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active span:nth-child(3) {
            transform: translateY(-8.5px) rotate(-45deg);
            background-color: var(--turk-mavisi);
        }

        .dropdown:hover .dropdown-content {
            display: none;
        }

        .dropdown.mobile-active .dropdown-content {
            display: block;
            position: relative;
            left: 0;
            transform: none;
            box-shadow: none;
            border: none;
            background: rgba(0,0,0,0.03);
            width: 100%;
            text-align: center;
            margin-top: 10px;
        }

        .logo img {
            height: 45px !important;
        }

        .logo-text {
            font-size: 14px;
            margin-left: 10px;
            white-space: normal;
        }

        }

        @@media (max-width: 480px) {
            nav

        {
            height: 70px;
            padding: 0 15px;
        }

        .logo img {
            height: 38px !important;
        }

        .logo-text {
            font-size: 12px;
            margin-left: 8px;
            line-height: 1.1;
        }

        .hamburger {
            width: 26px;
            height: 18px;
        }

            .hamburger.active span:nth-child(1) {
                transform: translateY(7.5px) rotate(45deg);
            }

            .hamburger.active span:nth-child(3) {
                transform: translateY(-7.5px) rotate(-45deg);
            }

        }

        /* 3. FOOTER */
        .site-footer {
            background-color: rgba(10, 10, 15, 0.9);
            color: #d1d5db;
            padding: 60px 20px 20px 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 50px;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            justify-content: space-between;
        }

        .footer-col {
            flex: 1;
            min-width: 250px;
        }

        .footer-logo {
            font-size: 24px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 20px;
            display: inline-block;
        }

            .footer-logo span {
                color: var(--turk-mavisi);
            }

        .footer-desc {
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 20px;
            color: #9ca3af;
        }

        .footer-title {
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            position: relative;
            padding-bottom: 10px;
        }

            .footer-title::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: 0;
                width: 40px;
                height: 3px;
                background: var(--turk-mavisi);
            }

        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .footer-links li {
                margin-bottom: 12px;
            }

            .footer-links a {
                color: #9ca3af;
                text-decoration: none;
                font-size: 14px;
                transition: 0.3s;
            }

                .footer-links a:hover {
                    color: var(--turk-mavisi);
                    padding-left: 5px;
                }

        .footer-contact {
            font-size: 14px;
            color: #9ca3af;
            line-height: 1.8;
        }

            .footer-contact strong {
                color: #fff;
                font-weight: 600;
            }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.05);
            margin-top: 40px;
            padding-top: 20px;
            text-align: center;
            font-size: 13px;
            color: #6b7280;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/" class="logo">
            <img src="~/images/logo.png" alt="Genç Finansçılar Derneği (GFD) Kurumsal Logosu" />
            <span class="logo-text">Genç Finansçılar<br>Derneği</span>
        </a>

        <div class="hamburger" id="hamburger-btn">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="menu" id="mobile-menu">
            <a href="/">Ana Sayfa</a>
            <a href="/hakkimizda">Hakkımızda</a>
            <a href="/koordinatorlukler">Koordinatörlükler</a>
            <a href="/paydaslar">Paydaşlar</a>
            <a href="/genc-zirveler">Genç Zirveler</a>

            <div class="dropdown" id="dropdown-menu">
                <a href="#" style="cursor: pointer;" id="dropdown-btn">Mevzuat-Formlar &#9662;</a>
                <div class="dropdown-content">
                    <a href="/tuzuk">Tüzük</a>
                    <a href="/faaliyet-belgesi">Faaliyet Belgesi</a>
                    <a href="/uyelik-basvurusu">Üyelik Başvuru Formu</a>
                </div>
            </div>

            <a href="/iletisim">İletişim</a>
        </div>
    </nav>

    <div class="main-content">
        @RenderBody()
    </div>

    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-col">
                <div class="footer-logo">GFD<span>.</span></div>
                <p class="footer-desc">Genç Finanscılar Derneği, iş dünyası ile gençler arasında köprü kurarak geleceğin liderlerini yetiştirmeyi hedefleyen vizyoner bir sivil toplum kuruluşudur.</p>
            </div>
            <div class="footer-col">
                <h4 class="footer-title">Hızlı Linkler</h4>
                <ul class="footer-links">
                    <li><a href="/">Ana Sayfa</a></li>
                    <li><a href="/hakkimizda">Hakkımızda</a></li>
                    <li><a href="/koordinatorlukler">Koordinatörlükler</a></li>
                    <li><a href="/genc-zirveler">Genç Zirveler</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4 class="footer-title">İletişim</h4>
                <div class="footer-contact">
                    <p><strong>Adres:</strong> Lalapaşa Mah. Cumhuriyet cad. Cumhuriyet İş Merkezi Kat:5 No: 209 Yakutiye - Erzurum</p>
                    <p><strong>Telefon:</strong> +90 442 502 36 22</p>
                    <p><strong>E-Posta:</strong> gfd@gfd.org.tr</p>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            &copy; 2026 Genç Finanscılar Derneği. Tüm hakları saklıdır.
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function() {

            // --- 1. MOBİL HAMBURGER MENÜ İŞLEMLERİ ---
            const hamburgerBtn = document.getElementById('hamburger-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            const dropdownBtn = document.getElementById('dropdown-btn');
            const dropdownMenu = document.getElementById('dropdown-menu');

            hamburgerBtn.addEventListener('click', function() {
                hamburgerBtn.classList.toggle('active');
                mobileMenu.classList.toggle('active');
            });

            // Mobilde Dropdown'a tıklanma işlemi
            dropdownBtn.addEventListener('click', function(e) {
                if (window.innerWidth <= 992) {
                    e.preventDefault();
                    dropdownMenu.classList.toggle('mobile-active');
                }
            });

            // --- 2. BEYAZ KUTULARI KOYU CAM EFEKTİNE ÇEVİRME ---
            document.querySelectorAll('.main-content div, .main-content section').forEach(el => {
                let bg = window.getComputedStyle(el).backgroundColor;
                let bgMatch = bg.match(/\d+/g);
                if(bgMatch && bgMatch.length >= 3) {
                    let r = parseInt(bgMatch[0]), g = parseInt(bgMatch[1]), b = parseInt(bgMatch[2]), a = bgMatch[3] !== undefined ? parseFloat(bgMatch[3]) : 1;
                    if(r > 240 && g > 240 && b > 240 && a > 0.5) {
                        el.style.setProperty('background-color', 'rgba(20, 20, 25, 0.8)', 'important');
                        el.style.setProperty('backdrop-filter', 'blur(10px)', 'important');
                        el.style.setProperty('border', '1px solid rgba(255, 255, 255, 0.1)', 'important');
                        el.style.setProperty('box-shadow', '0 10px 30px rgba(0,0,0,0.5)', 'important');
                    }
                }
            });

            // NOT: Önceki 3. ve 4. adımlardaki JavaScript kodları tasarımımızı ezdiği için temizlendi.

        });
    </script>
</body>
</html>