@{
    ViewData["Title"] = "Koordinatörlükler";
}

<style>
    /* YENİ KOYU KONSEPT KOORDİNATÖRLÜKLER KART TASARIMI */
    .teams-container {
        padding: 60px 20px;
        background-color: transparent;
        text-align: center;
    }

    .team-group {
        margin-bottom: 70px;
    }

        .team-group h3 {
            font-size: 26px;
            font-weight: 700;
            color: #3b82f6; /* Açık Mavi (Turk Mavisi) */
            margin-bottom: 30px;
            text-transform: uppercase;
            border-bottom: 3px solid #8b5cf6; /* Mor vurgu */
            display: inline-block;
            padding-bottom: 10px;
        }

    .team-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 25px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .team-card {
        background: rgba(20, 20, 25, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        padding: 20px 15px;
        width: 190px;
        border-bottom: 3px solid #8b5cf6;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        backdrop-filter: blur(10px);
    }

        .team-card:hover {
            transform: translateY(-8px);
            border-bottom: 3px solid #3b82f6;
            box-shadow: 0 10px 25px rgba(59, 130, 246, 0.3);
        }

    .team-photo {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 10px;
        border: 3px solid #2a2a35;
    }

    /* FOTOĞRAFI OLMAYANLAR İÇİN LOGO STİLİ */
    .logo-photo {
        object-fit: contain;
        background-color: #ffffff;
        padding: 10px;
    }

    /* AKADEMİK UNVANLAR İÇİN YENİ STİL */
    .team-title {
        font-size: 12px;
        color: #9ca3af;
        font-weight: 600;
        margin-bottom: 2px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .team-name {
        font-size: 15px;
        font-weight: 700;
        color: #d1d5db;
        margin-bottom: 5px;
        line-height: 1.3;
    }
</style>

