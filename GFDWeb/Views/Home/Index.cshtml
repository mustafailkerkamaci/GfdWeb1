@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    /* ANA RENKLER VE ZEMİN */
    :root {
        --koyu-zemin: #1b1b1b;
        --mor-vurgu: #8b5cf6;
        --mavi-vurgu: #3b82f6;
        --yazi-beyaz: #f8f9fa;
        --takvim-sari: #facc15;
    }

    /* BAŞLIKLAR */
    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

        .section-header h2 {
            font-size: 32px;
            font-weight: 800;
            color: var(--yazi-beyaz);
            display: inline-block;
            border-bottom: 4px solid var(--mavi-vurgu);
            padding-bottom: 10px;
            text-transform: uppercase;
        }

    /* 2. TAKVİM */
    .calendar-container {
        background: #1e1e1e;
        border-radius: 12px;
        border: 1px solid var(--mavi-vurgu);
        overflow: hidden;
        margin-bottom: 50px;
    }

    .calendar-header {
        background: var(--mavi-vurgu);
        color: white;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .calendar-header h3 {
            margin: 0;
            font-size: 22px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .calendar-header button {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
        }

            .calendar-header button:hover {
                background: rgba(255,255,255,0.4);
            }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        background: #1a1a1a;
        color: var(--takvim-sari);
        font-weight: 800;
        font-size: 13px;
        border-bottom: 1px solid #333;
    }

        .calendar-grid div {
            padding: 15px 0;
            text-transform: uppercase;
        }

    .calendar-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        background: #222;
    }

    .calendar-day {
        padding: 10px;
        border-bottom: 1px solid #333;
        border-right: 1px solid #333;
        color: #eee;
        min-height: 90px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 500;
        position: relative;
    }

        .calendar-day.empty {
            background: #1a1a1a;
            color: transparent;
            pointer-events: none;
        }

    /* Mor oval (Etkinlik Günü) */
    .event-day {
        background: var(--mor-vurgu) !important;
        color: white !important;
        cursor: pointer;
        border-radius: 20px;
        width: 45px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 10px rgba(139, 92, 246, 0.5);
    }

    /* 3. SAYAÇ BÖLÜMÜ */
    .counter-section {
        padding: 80px 20px;
        text-align: center;
        background: #151515;
    }

    .counters-container {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 80px;
        margin-top: 40px;
    }

    .counter-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 150px;
    }

    .counter-number {
        font-size: 56px;
        font-weight: 800;
        color: var(--mavi-vurgu);
        margin-bottom: 5px;
    }

        .counter-number::after {
            content: '+';
            font-weight: 300;
            margin-left: 2px;
        }

    .counter-label {
        font-size: 16px;
        color: var(--mor-vurgu);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* 4. ÖNE ÇIKANLAR */
    .highlights-section {
        padding: 80px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .highlights-grid {
        display: flex;
        gap: 30px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .highlight-card {
        flex: 1;
        min-width: 300px;
        max-width: 500px;
        background: #222;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #333;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        position: relative;
    }

    .hl-img-placeholder {
        height: 220px;
        background: var(--mavi-vurgu);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 50px;
    }

        .hl-img-placeholder.purple {
            background: var(--mor-vurgu);
        }

    .hl-content {
        padding: 25px;
    }

        .hl-content h3 {
            color: #fff;
            font-size: 22px;
            margin-bottom: 10px;
        }

        .hl-content p {
            color: #aaa;
            line-height: 1.6;
            margin-bottom: 20px;
            font-size: 15px;
        }

    .hl-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--mor-vurgu);
        color: white;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* TAKVİM İÇİN POP-UP (TOOLTIP) TASARIMI */
    .event-tooltip {
        visibility: hidden;
        background: #1e1e24;
        color: #fff;
        text-align: center;
        border-radius: 8px;
        padding: 12px 20px;
        position: absolute;
        z-index: 100;
        bottom: 85px;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        opacity: 0;
        transition: all 0.3s ease;
        border: 1px solid var(--mavi-vurgu);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        white-space: nowrap;
        font-size: 14px;
        font-weight: 700;
        pointer-events: none;
    }

        .event-tooltip::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -8px;
            border-width: 8px;
            border-style: solid;
            border-color: var(--mavi-vurgu) transparent transparent transparent;
        }

    .calendar-day:hover .event-tooltip {
        visibility: visible;
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    /* YENİ EKLENEN VİDEO BÖLÜMÜ TASARIMI */
    .video-section {
        padding: 60px 20px 20px;
        max-width: 1000px;
        margin: 0 auto;
        text-align: center;
    }

    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border: 2px solid rgba(139, 92, 246, 0.4);
        background: #000;
    }

        .video-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }

    /* AFİŞ BÖLÜMÜ TASARIMI - ORTALANMIŞ VERSİYON */
    .posters-grid {
        display: flex; /* Flexbox kullanarak içindekileri ortalıyoruz */
        justify-content: center; /* Yatayda ortalama */
        align-items: center;
        gap: 30px;
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .poster-item {
        max-width: 400px; /* Afişin ekranı tamamen kaplamasını engelliyoruz */
        width: 100%;
        display: block;
    }

        .poster-item img {
            width: 100%;
            height: auto;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .poster-item img:hover {
                transform: scale(1.03);
                box-shadow: 0 15px 40px rgba(139, 92, 246, 0.6);
            }


    /* 4. ÖNE ÇIKANLAR - SLIDER YAPI (YENİ EKLENDİ) */
    .highlights-section {
        padding: 80px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .highlights-slider {
        display: flex;
        gap: 30px;
        overflow-x: auto; /* Yatay kaydırmaya izin ver */
        scroll-snap-type: x mandatory; /* Kartların tam oturmasını sağlar */
        padding-bottom: 20px; /* Kaydırma çubuğu için boşluk */
    }

        /* Windows kaydırma çubuğunu şıklaştıralım */
        .highlights-slider::-webkit-scrollbar {
            height: 8px;
        }

        .highlights-slider::-webkit-scrollbar-thumb {
            background: var(--mor-vurgu);
            border-radius: 10px;
        }

        .highlights-slider::-webkit-scrollbar-track {
            background: #222;
            border-radius: 10px;
        }

    .highlight-card {
        flex: 0 0 auto; /* Kartların sıkışıp küçülmesini engeller */
        width: 350px; /* Her kartın sabit genişliği */
        scroll-snap-align: start; /* Kaydırırken kartın başına yapışır */
        background: #222;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #333;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        position: relative;
    }
    /* Mobil uyum için genişliği ayarla */
    @@media (max-width: 576px) {
        .highlight-card

    {
        width: 300px;
    }

    }

    /* (Mevcut .hl-img-placeholder, .hl-content, .hl-badge CSS kodların aynen kalabilir) */
</style>

<section class="video-section">
    <div class="video-container">
        <iframe src="https://www.youtube.com/embed/dCxZ9BLcRTw?autoplay=1&mute=1" title="GFD Tanıtım Videosu" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
    </div>
</section>

<section class="posters-grid">
    <a href="/genc-zirveler" class="poster-item">
        <img src="~/images/etkinlik_kadin_izi.jpeg" alt="Kadın İzi İşte Kadın İşte Hayat" />
    </a>
</section>

<section class="calendar-section" style="padding: 80px 20px; max-width: 1000px; margin: 0 auto;">
    <div class="section-header">
        <h2>Etkinlik Takvimi</h2>
    </div>

    <div class="calendar-container">
        <div class="calendar-header">
            <button id="prevMonth">&laquo; Önceki</button>
            <h3 id="monthYearDisplay"></h3> <button id="nextMonth">Sonraki &raquo;</button>
        </div>
        <div class="calendar-grid">
            <div>Pzt</div><div>Sal</div><div>Çar</div><div>Per</div><div>Cum</div><div>Cmt</div><div>Paz</div>
        </div>
        <div class="calendar-days" id="calendarDays"></div>
    </div>
</section>

<section class="counter-section" id="counter-bolumu">
    <div class="section-header" style="margin-bottom: 20px;">
        <h2>GFD Etkisi</h2>
    </div>
    <p style="color: #888; font-size: 16px;">Yerel, ulusal ve uluslararası projelerimizle gençleri geleceğe hazırlıyoruz</p>

    <div class="counters-container">
        <div class="counter-box">
            <div class="counter-number" data-target="30">0</div>
            <div class="counter-label">İş Ortaklığı</div>
        </div>
        <div class="counter-box">
            <div class="counter-number" data-target="50">0</div>
            <div class="counter-label">Ana Paydaşlar</div>
        </div>
        <div class="counter-box">
            <div class="counter-number" data-target="5000">0</div>
            <div class="counter-label">Ulaşılan Gençler</div>
        </div>
    </div>
</section>

<section class="highlights-section">
    <div class="section-header">
        <h2>Öne Çıkanlar</h2>
    </div>

    <div class="highlights-slider">

        <div class="highlight-card">
            <div class="hl-badge">Çok Yakında</div>
            <div class="hl-img-placeholder">📰</div>
            <div class="hl-content">
                <h3>İlk Makalemiz Hazırlanıyor</h3>
                <p>Finans, ekonomi ve kariyer üzerine alanında uzman isimlerin kaleme aldığı makaleler ve dernek haberlerimiz çok yakında bu alanda yayınlanacaktır.</p>
                <a href="/makaleler" style="color: var(--mavi-vurgu); font-weight: 600; text-decoration: none;">Devamını Oku &rarr;</a>
            </div>
        </div>

        <div class="highlight-card">
            <div class="hl-badge" style="background: var(--mavi-vurgu);">Duyuru</div>
            <div class="hl-img-placeholder purple">📢</div>
            <div class="hl-content">
                <h3>Dernek Tanıtım Dosyası</h3>
                <p>Yönetim kurulumuzun ve koordinatörlerimizin titizlikle hazırladığı, derneğimizin vizyonunu anlatan faaliyet sunumlarımız çok yakında yayında.</p>
                <a href="/makaleler" style="color: var(--mavi-vurgu); font-weight: 600; text-decoration: none;">Devamını Oku &rarr;</a>
            </div>
        </div>

    </div>
</section>

<script>
    // --- 1. DİNAMİK TAKVİM KODLARI ---
    const monthNames = ["Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık"];
    let currentMonth = new Date().getMonth(); // Otomatik olarak bulunduğumuz ayı alır
    let currentYear = new Date().getFullYear(); // Otomatik olarak bulunduğumuz yılı alır

    function renderCalendar() {
        const daysContainer = document.getElementById('calendarDays');
        const monthYearDisplay = document.getElementById('monthYearDisplay');
        daysContainer.innerHTML = '';
        monthYearDisplay.innerText = `${monthNames[currentMonth]} ${currentYear}`;

        const firstDay = new Date(currentYear, currentMonth, 1).getDay();
        const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
        let startDay = firstDay === 0 ? 6 : firstDay - 1;

        for(let i = 0; i < startDay; i++) {
            daysContainer.innerHTML += `<div class="calendar-day empty"></div>`;
        }
        for(let i = 1; i <= daysInMonth; i++) {

            // JavaScript'te Aylar 0'dan başlar (0=Ocak, 1=Şubat, 2=Mart, 3=Nisan).
            // 3. ayın (Nisan) 18. günü için şart yazıyoruz:
            if(currentMonth === 3 && i === 18) {
                daysContainer.innerHTML += `
                    <div class="calendar-day" style="cursor: pointer;" onclick="window.location.href='/genc-zirveler'">
                        <div class="event-day">${i}</div>
                        <div class="event-tooltip">Kadın İzi</div>
                    </div>`;
            } else {
                daysContainer.innerHTML += `<div class="calendar-day">${i}</div>`;
            }
        }
    }

    document.getElementById('prevMonth').addEventListener('click', () => {
        currentMonth--; if(currentMonth < 0) { currentMonth = 11; currentYear--; }
        renderCalendar();
    });

    document.getElementById('nextMonth').addEventListener('click', () => {
        currentMonth++; if(currentMonth > 11) { currentMonth = 0; currentYear++; }
        renderCalendar();
    });

    // Sayfa yüklendiğinde takvimi çiz
    renderCalendar();

    // --- 2. AKILLI SAYAÇ KODLARI ---
    const counters = document.querySelectorAll('.counter-number');
    const speed = 200;
    const counterObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const counter = entry.target;
                const updateCount = () => {
                    const target = +counter.getAttribute('data-target');
                    const count = +counter.innerText.replace(/,/g, '');
                    const inc = target / speed;
                    if (count < target) {
                        counter.innerText = Math.ceil(count + inc).toLocaleString('en-US');
                        setTimeout(updateCount, 15);
                    } else {
                        counter.innerText = target.toLocaleString('en-US');
                    }
                };
                updateCount();
                observer.unobserve(counter);
            }
        });
    }, { threshold: 0.5 });

    counters.forEach(counter => { counterObserver.observe(counter); });
</script>