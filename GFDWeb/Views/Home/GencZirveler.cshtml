@{
    ViewData["Title"] = "Genç Zirveler";
}

<style>
    /* YENİ KOYU KONSEPT GENÇ ZİRVELER SAYFASI */
    .zirve-section {
        padding: 80px 20px;
        text-align: center;
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent;
    }

    .zirve-title {
        font-size: 32px;
        font-weight: 800;
        color: #3b82f6;
        margin-bottom: 40px;
        text-transform: uppercase;
        border-bottom: 3px solid #8b5cf6;
        display: inline-block;
        padding-bottom: 12px;
    }

    /* AFİŞ ORTALAMA İÇİN FLEXBOX (YENİ EKLENDİ) */
    .zirve-grid {
        display: flex; /* Öğeleri yan yana ve ortalı dizmek için Flexbox kullandık */
        justify-content: center; /* Yatayda tam ortaya alır */
        align-items: center;
        gap: 30px;
        width: 100%;
        max-width: 1200px;
    }

    /* AFİŞ İÇİN ÖZEL CAM EFEKTLİ KART TASARIMI */
    .poster-item {
        max-width: 400px; /* Afişin ekranı devasa kaplamasını önler */
        width: 100%;
        display: block;
        transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    }

        .poster-item:hover {
            transform: translateY(-8px);
        }

        .poster-item img {
            width: 100%;
            height: auto;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: block;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .poster-item img:hover {
                transform: scale(1.03);
                box-shadow: 0 15px 40px rgba(139, 92, 246, 0.6);
            }
</style>

<div class="zirve-section">
    <h1 class="zirve-title">Genç Zirveler</h1>

    <div class="zirve-grid">
        <a href="/genc-zirveler" class="poster-item">
            <img src="~/images/etkinlik_kadin_izi.jpeg" alt="Kadın İzi İşte Kadın İşte Hayat" />
        </a>
    </div>
</div>