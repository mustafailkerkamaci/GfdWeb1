@{
    ViewData["Title"] = "Genç Zirveler";
}

<style>
    /* YENİ KOYU KONSEPT GENÇ ZİRVELER SAYFASI */
    .zirve-section {
        padding: 80px 20px;
        text-align: center;
        min-height: 60vh; /* Sayfanın altını çok boş bırakmamak için */
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent; /* Arka plandaki ana mor/lacivert geçişi görebilmek için */
    }

    .zirve-title {
        font-size: 32px;
        font-weight: 800;
        color: #3b82f6; /* Türk Mavisi */
        margin-bottom: 40px;
        text-transform: uppercase;
        border-bottom: 3px solid #8b5cf6; /* Mor Vurgu */
        display: inline-block;
        padding-bottom: 12px;
    }

    /* AFİŞ İÇİN ÖZEL CAM EFEKTLİ KART TASARIMI */
    .event-card {
        background: rgba(20, 20, 25, 0.8); /* Koyu yarı saydam zemin */
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5); /* Derinlik veren gölge */
        border: 1px solid rgba(255, 255, 255, 0.1); /* İnce şık çerçeve */
        backdrop-filter: blur(10px); /* Cam efekti */
        max-width: 800px; /* Afişin devasa olmasını engeller */
        width: 100%;
        transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    }

        .event-card:hover {
            transform: translateY(-8px); /* Üzerine gelince hafif yukarı kalkar */
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.4); /* Mor parlama artar */
            border-color: #3b82f6; /* Çerçeve maviye döner */
        }

        .event-card img {
            width: 100%;
            height: auto;
            border-radius: 12px; /* Resmin köşeleri de kartla uyumlu oval olur */
        }
</style>

<div class="zirve-section">
    <h1 class="zirve-title">Genç Zirveler</h1>

    <div class="event-card">
        <img src="~/images/etkinlik.jpeg" alt="26 Mart İş Dünyası Öğrenci Buluşmaları Finans Zirvesi Etkinlik Afişi" />
    </div>
</div>