@{
    ViewData["Title"] = "Genç Zirveler";
}

<style>
    /* YENİ KOYU KONSEPT GENÇ ZİRVELER SAYFASI */
    .zirve-section {
        padding: 80px 20px;
        text-align: center;
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: transparent;
    }

    .zirve-title {
        font-size: 32px;
        font-weight: 800;
        color: #3b82f6;
        margin-bottom: 40px;
        text-transform: uppercase;
        border-bottom: 3px solid #8b5cf6;
        display: inline-block;
        padding-bottom: 12px;
    }

    /* 3'LÜ AFİŞ IZGARASI (YENİ EKLENDİ) */
    .zirve-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* Bilgisayarda 3'lü */
        gap: 30px;
        width: 100%;
        max-width: 1200px;
    }

    /* AFİŞ İÇİN ÖZEL CAM EFEKTLİ KART TASARIMI */
    .event-card {
        background: rgba(20, 20, 25, 0.8);
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        width: 100%;
        box-sizing: border-box; /* İŞTE KARTLARIN SIKIŞMASINI ENGELLEYEN SİHİRLİ KOD */
        transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    }

        .event-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(139, 92, 246, 0.4);
            border-color: #3b82f6;
        }

        .event-card img {
            width: 100%;
            height: auto;
            border-radius: 12px;
            display: block; /* Resmin altındaki o gereksiz boşluğu siler */
        }

    /* MOBİL VE TABLET UYUMU (RESPONSIVE) */
    @@media (max-width: 992px) {
        .zirve-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .zirve-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="zirve-section">
    <h1 class="zirve-title">Genç Zirveler</h1>

    <div class="zirve-grid">
        <div class="event-card">
            <img src="~/images/is_dunyasi_kariyer_paneli.png" alt="İş Dünyası Kariyer Paneli" />
        </div>

        <div class="event-card">
            <img src="~/images/etkinlik.jpeg" alt="26 Mart İş Dünyası Öğrenci Buluşmaları" />
        </div>

        <div class="event-card">
            <img src="~/images/muhasebe_denetim_paneli_afis.png" alt="Muhasebe ve Denetim Paneli" />
        </div>
    </div>
</div>