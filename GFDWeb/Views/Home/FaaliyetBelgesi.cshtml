@{
    ViewData["Title"] = "Faaliyet Belgesi";
}

<style>
    .pdf-wrapper {
        max-width: 1000px;
        margin: 60px auto;
        background: rgba(30, 30, 30, 0.6); /* Arka plandaki neon ışıkları hafif göstersin diye yarı saydam siyah */
        backdrop-filter: blur(10px); /* Şık bir cam efekti */
        padding: 20px;
        border-radius: 15px;
        border: 1px solid rgba(139, 92, 246, 0.3); /* Hafif mor çerçeve */
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .page-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #f8f9fa;
            text-transform: uppercase;
            display: inline-block;
            border-bottom: 4px solid #3b82f6; /* Mavi alt çizgi */
            padding-bottom: 10px;
        }
</style>

<div class="pdf-wrapper">
    <div class="page-header">
        <h1>Faaliyet Belgesi</h1>
    </div>

    <iframe src="/images/faaliyet_belgesi.pdf"
            width="100%"
            height="800px"
            style="border: none; border-radius: 8px; background-color: white;">
        <p>
            Tarayıcınız PDF görüntülemeyi desteklemiyor.
            <a href="/images/faaliyet_belgesi.pdf" style="color: #3b82f6;">Belgeyi indirmek için tıklayın.</a>
        </p>
    </iframe>
</div>