@{
    ViewData["Title"] = "Üyelik Başvurusu";
}

<style>
    .pdf-wrapper {
        max-width: 1000px;
        margin: 60px auto;
        background: rgba(30, 30, 30, 0.6); /* Şık yarı saydam zemin */
        backdrop-filter: blur(10px); /* Cam efekti */
        padding: 20px;
        border-radius: 15px;
        border: 1px solid rgba(59, 130, 246, 0.3); /* Mavi çerçeve */
        box-shadow: 0 15px 35px rgba(0,0,0,0.5);
    }

    .page-header {
        text-align: center;
        margin-bottom: 20px;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: 800;
            color: #f8f9fa;
            text-transform: uppercase;
            display: inline-block;
            border-bottom: 4px solid #3b82f6; /* Mavi alt çizgi */
            padding-bottom: 10px;
        }

    .print-note {
        text-align: center;
        color: #ddd;
        margin-bottom: 25px;
        font-size: 16px;
        background: rgba(59, 130, 246, 0.1);
        padding: 15px;
        border-radius: 8px;
        border-left: 4px solid #3b82f6;
    }
</style>

<div class="pdf-wrapper">
    <div class="page-header">
        <h1>Üyelik Başvuru Dilekçesi</h1>
    </div>

    <div class="print-note">
        <strong>Başvuru Süreci:</strong> Aramıza katılmak için aşağıdaki başvuru formunu indirip eksiksiz şekilde doldurarak
        <a href="mailto:gfd@gfd.org.tr" style="color: #3b82f6; font-weight: bold; text-decoration: underline;">gfd@gfd.org.tr</a>
        e-posta adresine göndermeniz yeterlidir. Başvurunuz incelendikten sonra tarafınıza dönüş sağlanacaktır.
    </div>

    <iframe src="/images/uyelik_dilekcesi.pdf"
            width="100%"
            height="800px"
            style="border: none; border-radius: 8px; background-color: white;">
        <p>
            Tarayıcınız PDF görüntülemeyi desteklemiyor.
            <a href="/images/uyelik_dilekcesi.pdf" style="color: #3b82f6;">Dilekçeyi indirmek için tıklayın.</a>
        </p>
    </iframe>
</div>